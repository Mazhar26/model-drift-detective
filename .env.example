# ─────────────────────────────────────────────
# .env.example — Environment Variables
# Model Drift Detective
# ─────────────────────────────────────────────
# Copy this file to .env and update as needed:
#   cp .env.example .env

# ── API Configuration ──
API_HOST=localhost
API_PORT=8000

# ── Streamlit Configuration ──
STREAMLIT_PORT=8501

# ── Drift Detection ──
DEFAULT_THRESHOLD=0.1
P_VALUE_THRESHOLD=0.05
SEVERITY_HIGH_THRESHOLD=0.3
SEVERITY_MEDIUM_THRESHOLD=0.1

# ── Logging ──
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=app.log

# ── Data ──
DATA_PATH=data/WA_Fn-UseC_-Telco-Customer-Churn.csv

# ── Model Parameters ──
MODEL_N_ESTIMATORS=100
MODEL_RANDOM_STATE=42
# MODEL_MAX_DEPTH=10  # Uncomment to set max depth

# ── Database ──
DB_DIR=data

# ── Email Alerts ──
ALERTS_ENABLED=false
ALERT_THRESHOLD=0.3
ALERT_EMAIL_FROM=your@email.com
ALERT_EMAIL_TO=recipient@email.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_PASSWORD=your_app_password
